generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ContentType {
  NOTICE
  EVENT
  ACHIEVEMENT
}

model Department {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  slug                  String    @unique
  shortName             String?
  overview              String?
  hodName               String?
  coverImageUrl         String?
  sourceUrl             String?
  academicDetailsPdfUrl String?
  displayOrder          Int       @default(0)
  isActive              Boolean   @default(true)
  faculties             Faculty[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([displayOrder])
  @@index([name])
}

model Faculty {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  departmentId String     @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id])
  name         String
  roleKey      String
  roleLabel    String
  designation  String?
  specialization String?
  imageUrl     String?
  profileUrl   String?
  bio          String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId, roleKey, sortOrder])
  @@index([departmentId, isActive])
  @@index([roleKey])
}

model FacultyRoleHierarchy {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  key          String   @unique
  label        String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
}

model PrincipalMessage {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  key             String   @unique @default("principal_message")
  name            String
  designation     String
  message         String
  profileImageUrl String
  officeEmail     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContentDocument {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  type        ContentType
  title       String
  description String
  pdfUrl      String
  pdfPublicId String?
  isActive    Boolean     @default(true)
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type, publishedAt])
  @@index([type, isActive])
}
